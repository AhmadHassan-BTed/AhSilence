# ===================================================================
# AhSilence — .gitattributes
# ===================================================================

# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Kotlin / Java source
*.kt text diff=kotlin
*.java text diff=java
*.kts text diff=kotlin

# Build & Config
*.xml text
*.properties text
*.toml text
*.pro text
*.gradle text
*.yml text
*.yaml text
*.json text
*.md text

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf
gradlew text eol=lf
gradlew.bat text eol=crlf

# Binary assets — do not diff
*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.jar binary
*.jks binary
*.keystore binary
